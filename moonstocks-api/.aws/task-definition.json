{
  "containerDefinitions": [
    {
      "name": "moonstocks-api",
      "image": "550822830987.dkr.ecr.eu-north-1.amazonaws.com/moonstocks-api-prod:PLACEHOLDER",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "moonstocks-api-port-8080",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "Analyzer__BaseUrl",
          "value": "http://moonstocks-ai-analyzer-prod:8000"
        }
      ],
      "secrets": [
        {
          "name": "ConnectionStrings__SqlServer",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:550822830987:secret:moonstocks-db-secrets-prod-Cr3qgH:moonstocks-db-prod-connection-string::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/moonstocks-api-prod",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "family": "moonstocks-api-prod",
  "executionRoleArn": "arn:aws:iam::550822830987:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "enableFaultInjection": false
}
