{
  "containerDefinitions": [
    {
      "name": "moonstocks-ai-analyzer",
      "image": "550822830987.dkr.ecr.eu-north-1.amazonaws.com/moonstocks-ai-analyzer-prod:PLACEHOLDER",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "name": "moonstocks-ai-analyzer-port-8000",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "ANALYSIS_API_BASE_URL",
          "value": "http://equity-os-prod:3000"
        },
        {
          "name": "ANALYZER_LLM_PROVIDER",
          "value": "openai"
        },
        {
          "name": "OPENAI_MODEL",
          "value": "gpt-4o"
        }
      ],
      "secrets": [
        {
          "name": "EODHD_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:550822830987:secret:moonstocks-analyzer-ai-secrets-prod-7lVjMT:EODHD_API_KEY::"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:550822830987:secret:moonstocks-analyzer-ai-secrets-prod-7lVjMT:OPENAI_API_KEY::"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:550822830987:secret:moonstocks-analyzer-ai-secrets-prod-7lVjMT:ANTHROPIC_API_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/moonstocks-ai-analyzer-prod",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "family": "moonstocks-ai-analyzer-prod",
  "executionRoleArn": "arn:aws:iam::550822830987:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "enableFaultInjection": false
}
