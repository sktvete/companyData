# LLM provider: openai | anthropic (optional — auto: OpenAI if only OPENAI_API_KEY is set)
ANALYZER_LLM_PROVIDER=openai
# ANALYZER_LLM_PREFER=openai

# OpenAI (stock-analysis skill + EODHD REST prefetch)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Claude API (claude-agent-sdk + EODHD MCP) — omit if using OpenAI only
ANTHROPIC_API_KEY=

# EODHD — required for both providers
EODHD_API_KEY=

# Flask backend API base URL (no trailing slash) - companyData Flask app
ANALYSIS_API_BASE_URL=http://localhost:3000

# Shared secret required in X-API-Key header on inbound requests
ANALYZER_API_KEY=
