# Copy to .env for docker-compose.moonstocks.yml (equity-os + analyzer)
EODHD_API_KEY=
OPENAI_API_KEY=
ANALYZER_LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
MOONSTOCKS_ANALYZER_URL=http://analyzer:8000
MOONSTOCKS_DATABASE_URL=postgresql://moonstocks:moonstocks@postgres:5432/moonstocks
# Native host dev (run_server.py): use .env.native.example (@127.0.0.1) + `docker compose … up -d postgres`
# Optional shared secret (must match moonstocks-ai-analyzer/.env ANALYZER_API_KEY)
ANALYZER_API_KEY=
# Tracker AI Research Agent
# SEC EDGAR User-Agent — must be "<name> <email>", e.g. "Your Name research@yourdomain.com"
SEC_EDGAR_USER_AGENT=
# Optional: Firecrawl API key for deeper web search (https://firecrawl.dev)
FIRECRAWL_API_KEY=
# Tracker research LLM: auto (Codex if signed in and no sk- key), codex, or openai
# TRACKER_LLM_PROVIDER=auto
# CODEX_CHAT_MODEL=gpt-5.5
