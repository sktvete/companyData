# Native dev on the host (Flask + uvicorn) with the same Postgres as Docker/prod.
# 1) docker compose -f docker-compose.moonstocks.yml up -d postgres
# 2) Copy these lines into .env (replace any MOONSTOCKS_DATABASE_URL that uses host "postgres")

EODHD_API_KEY=
OPENAI_API_KEY=
ANALYZER_LLM_PROVIDER=openai
MOONSTOCKS_ANALYZER_URL=http://127.0.0.1:8000
MOONSTOCKS_DATABASE_URL=postgresql://moonstocks:moonstocks@127.0.0.1:5432/moonstocks
# Do not set MOONSTOCKS_DB_PATH — storage is Postgres only outside unit tests.
