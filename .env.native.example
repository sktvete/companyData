# Native dev on the host (Flask + uvicorn).
#
# Option A — SQLite (no Docker needed, recommended for local dev):
#   Set MOONSTOCKS_DB_PATH and leave MOONSTOCKS_DATABASE_URL commented out.
#
# Option B — Postgres (production-like):
#   1) docker compose -f docker-compose.moonstocks.yml up -d postgres
#   2) Comment out MOONSTOCKS_DB_PATH and set MOONSTOCKS_DATABASE_URL.

EODHD_API_KEY=
OPENAI_API_KEY=
ANALYZER_LLM_PROVIDER=openai
MOONSTOCKS_ANALYZER_URL=http://127.0.0.1:8000

# Session cookie signing (set in production — favorites/login persist per browser)
# FLASK_SECRET_KEY=

# Option A: SQLite (local, no Docker)
MOONSTOCKS_DB_PATH=./moonstocks_local.db

# Option B: Postgres
# MOONSTOCKS_DATABASE_URL=postgresql://moonstocks:moonstocks@127.0.0.1:5432/moonstocks
