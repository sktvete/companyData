# Copy to project root as `.env` (never commit real keys).
# Chat: sign in with ChatGPT on a company page (Ask AI). Session → outputs/.chatgpt_session.json
CODEX_CHAT_MODEL=gpt-5.4
# Optional chat tuning:
# OPENAI_CHAT_MAX_TOOL_ROUNDS=6
# CHAT_EODHD_SNAPSHOT_MAX_CHARS=32000
# OPENAI_CHAT_MAX_INPUT=8000
# OPENAI_CHAT_MAX_TURNS=16

# EODHD (existing app usage)
EODHD_API_KEY=
# Universe scan: parallel fundamentals fetches (default 200; lower if you hit 429 rate limits)
EODHD_FETCH_CONCURRENCY=200
