# Copy to project root as `.env` (never commit real keys).
# Chat: prefer ChatGPT subscription (Sign in on company page). Session saved to outputs/.chatgpt_session.json
# Optional fallback if not signed in:
OPENAI_API_KEY=
CODEX_CHAT_MODEL=gpt-5.4
OPENAI_CHAT_MODEL=gpt-5-mini
# Latency: each request may run a tool round (EODHD) before tokens; smaller models answer faster.
# Examples: gpt-4o-mini (often lower latency than GPT-5 family), gpt-4o, gpt-5-mini (default).
# Optional tuning (defaults favor short replies; stream caps at 2048):
# OPENAI_CHAT_MAX_TOKENS=512
# OPENAI_CHAT_STREAM_MAX_TOKENS=512
# OPENAI_CHAT_TEMPERATURE=0.35

# EODHD (existing app usage)
EODHD_API_KEY=
# Universe scan: parallel fundamentals fetches (default 200; lower if you hit 429 rate limits)
EODHD_FETCH_CONCURRENCY=200
