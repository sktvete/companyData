# ============================================================================
# equity-os  ·  AWS production environment variables
# ============================================================================
# These are injected via ECS task definition "secrets" from Secrets Manager.
# Do NOT commit real values.  Store them in AWS Secrets Manager and reference
# the ARNs in ecs-equity-os.yaml.

# ── Required ─────────────────────────────────────────────────────────────────

# EODHD data API (fundamentals, quotes, estimates)
EODHD_API_KEY=

# OpenAI (chat + AI analysis)
OPENAI_API_KEY=

# PostgreSQL connection string (from rds-moonstocks.yaml output)
MOONSTOCKS_DATABASE_URL=postgresql://moonstocks:<password>@<rds-endpoint>:5432/moonstocks

# Shared secret between equity-os and the analyzer (any random 32-char string)
ANALYZER_API_KEY=

# ── Service topology ─────────────────────────────────────────────────────────

# Internal URL of the moonstocks-ai-analyzer service (Cloud Map DNS)
MOONSTOCKS_ANALYZER_URL=http://analyzer.equity-os.local:8000

# ── Optional ─────────────────────────────────────────────────────────────────

# If set, sync outputs/ from S3 at container startup (populates EFS on first run)
# OUTPUTS_S3_URI=s3://my-equity-os-bucket/outputs

# Gunicorn tuning (defaults in gunicorn.conf.py are production-ready)
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=300
# GUNICORN_LOG_LEVEL=info

# AI chat model override (default: gpt-5.3-codex)
# CODEX_CHAT_MODEL=gpt-5.3-codex
# OPENAI_CHAT_MODEL=gpt-4.1-mini

# Chat limits
# OPENAI_CHAT_MAX_INPUT=8000
# OPENAI_CHAT_MAX_TURNS=16
# OPENAI_CHAT_MAX_TOOL_ROUNDS=6

# SEC Edgar user agent (for EDGAR requests)
# SEC_EDGAR_USER_AGENT=YourCompany equity-research contact@yourcompany.com

# ── GitHub Actions variables (set in repo Settings → Secrets and variables) ──
#
#   AWS_REGION         eu-north-1
#   ECR_REPOSITORY     equity-os          (repository name, not full URI)
#   CONTAINER_NAME     equity-os          (matches ContainerDefinitions[].Name in task def)
#   ECS_SERVICE        equity-os          (ECS service name)
#   ECS_CLUSTER        moonstocks-prod    (ECS cluster name)
#
#   AWS_ROLE_ARN       arn:aws:iam::550822830987:role/github-actions-deploy
#                      (secret — GitHub OIDC role with ECR push + ECS update permissions)
